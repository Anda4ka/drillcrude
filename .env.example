# === CRUDE Driller Config ===
# Copy this file to .env and fill in your values

# Bankr wallet (get at https://bankr.bot)
BANKR_API_KEY=
DRILLER_ADDRESS=

# Coordinator (default is fine)
COORDINATOR_URL=https://coordinator-production-38c0.up.railway.app

# === LLM Backend ===
# "openrouter" — any model via OpenRouter (needs OPENROUTER_API_KEY)
# "zai"        — GLM models via ZAI SDK (needs ZAI_API_KEY, free)
LLM_BACKEND=openrouter

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# ZAI SDK (for GLM-5, free — https://open.bigmodel.cn)
ZAI_API_KEY=

# Model (depends on backend):
# OpenRouter: openai/gpt-4o-mini, openai/gpt-4o, anthropic/claude-sonnet-4, deepseek/deepseek-r1
# ZAI: glm-5, glm-4.7
LLM_MODEL=openai/gpt-4o-mini

# Debug (true = log challenges + LLM responses to crude_debug.log)
DRILLER_DEBUG=false
