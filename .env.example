# === CRUDE Driller v6.8 Config ===
# Copy this file to .env and fill in your values

# ======== SINGLE WALLET (simple mode) ========

# Bankr wallet (get at https://bankr.bot/api)
# Enable Agent API and disable read-only!
BANKR_API_KEY=
# Wallet address - MUST match the address linked to your Bankr API key!
# Bot will verify on startup. If mismatch - receipts will fail on-chain.
DRILLER_ADDRESS=

# Staking tier: wildcat (25M) / platform (50M) / deepwater (100M)
DRILLER_TIER=platform

# ======== MULTI-WALLET (optional) ========
# If BANKR_API_KEY_1 is set, bot switches to multi-wallet mode.
# Plain BANKR_API_KEY above will be ignored.

# BANKR_API_KEY_1=first_wallet_key
# DRILLER_ADDRESS_1=0xAAA...    # must match Bankr API key 1 wallet!
# DRILLER_TIER_1=platform

# BANKR_API_KEY_2=second_wallet_key
# DRILLER_ADDRESS_2=0xBBB...    # must match Bankr API key 2 wallet!
# DRILLER_TIER_2=wildcat

# ======== OPTIONAL ========

# Coordinator (default is fine)
# COORDINATOR_URL=https://coordinator-production-38c0.up.railway.app

# Telegram notifications (gushers, errors, stats)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Logging mode
# DRILLER_DEBUG=false
# DRILLER_QUIET=false

# ======== LLM (NOT required) ========
# Bot solves ~95% challenges without AI. LLM is only a fallback.
# If no key is set - bot will just skip unsolvable challenges.

# "openrouter" - any model via OpenRouter (needs OPENROUTER_API_KEY)
# "zai"        - GLM models via ZAI SDK (needs ZAI_API_KEY, free)
# LLM_BACKEND=zai
# LLM_MODEL=glm-5
# ZAI_API_KEY=
# OPENROUTER_API_KEY=
