# === CRUDE Driller v6.8 Config ===
# Copy this file to .env and fill in your values

# ======== ОДИН КОШЕЛЁК (простой режим) ========

# Bankr wallet (get at https://bankr.bot/api)
# Включи Agent API и отключи read-only!
BANKR_API_KEY=
DRILLER_ADDRESS=

# Стейкинг тир: wildcat (25M) / platform (50M) / deepwater (100M)
DRILLER_TIER=platform

# ======== НЕСКОЛЬКО КОШЕЛЬКОВ (опционально) ========
# Если указать BANKR_API_KEY_1, бот перейдёт в multi-wallet режим.
# Простой BANKR_API_KEY выше будет проигнорирован.

# BANKR_API_KEY_1=ключ_первого_кошелька
# DRILLER_ADDRESS_1=0xAAA...
# DRILLER_TIER_1=platform

# BANKR_API_KEY_2=ключ_второго_кошелька
# DRILLER_ADDRESS_2=0xBBB...
# DRILLER_TIER_2=wildcat

# ======== ОПЦИОНАЛЬНО ========

# Coordinator (default is fine)
# COORDINATOR_URL=https://coordinator-production-38c0.up.railway.app

# Telegram-уведомления (гашеры, ошибки, статистика)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Режим логирования
# DRILLER_DEBUG=false
# DRILLER_QUIET=false

# ======== LLM (НЕ обязательно) ========
# Бот решает ~95% challenges без AI. LLM нужен только как fallback.
# Если не указать ключ — бот просто пропустит нерешаемые задачи.

# "openrouter" — any model via OpenRouter (needs OPENROUTER_API_KEY)
# "zai"        — GLM models via ZAI SDK (needs ZAI_API_KEY, free)
# LLM_BACKEND=zai
# LLM_MODEL=glm-5
# ZAI_API_KEY=
# OPENROUTER_API_KEY=
